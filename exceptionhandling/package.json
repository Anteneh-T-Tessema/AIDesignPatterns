{
  "name": "exceptionhandling",
  "version": "1.0.0",
  "type": "module",
  "description": "Exception Handling and Recovery agentic design pattern — resilient LLM agent using Ollama + Llama 3.2",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "scenario:retry": "node index.js --scenario retry",
